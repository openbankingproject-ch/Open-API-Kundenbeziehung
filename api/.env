# Development environment configuration for interactive demo
NODE_ENV=development
PORT=3000

# Skip authentication for demo
SKIP_CLIENT_AUTH=true

# JWT Configuration (development only)
JWT_SECRET=dev-secret-key-for-demo-purposes-only-change-in-production-must-be-at-least-256-bits
JWT_ISSUER=open-api-kundenbeziehung
JWT_EXPIRY=1h

# CORS Configuration (allow local development)
ALLOWED_ORIGINS=https://localhost:3000,http://localhost:3000

# External URLs
CONSENT_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000/v1

# mTLS Configuration (skip for demo)
SKIP_MTLS=true

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/api.log

# Rate Limiting (relaxed for demo)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Development Only
DEV_MOCK_EXTERNAL_SERVICES=true
DEV_GENERATE_TEST_DATA=true
DEV_SKIP_SIGNATURE_VALIDATION=true
